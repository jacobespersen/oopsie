{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "TodoWrite",
      "Agent",
      "Bash(*)",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id",
      "mcp__obsidian__get_vault_stats",
      "mcp__obsidian__read_note",
      "mcp__obsidian__write_note",
      "mcp__obsidian__list_directory",
      "mcp__obsidian__search_notes",
      "mcp__obsidian__patch_note",
      "mcp__obsidian__get_notes_info",
      "mcp__obsidian__get_frontmatter",
      "mcp__obsidian__update_frontmatter",
      "mcp__obsidian__manage_tags",
      "mcp__obsidian__read_multiple_notes",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rm -*)",
      "Bash(git reset --hard*)",
      "Read(**/.env*)",
      "Edit(**/.env*)",
      "Write(**/.env*)",
      "Bash(*git*.env*)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(chmod *)",
      "Bash(mkfs *)",
      "Bash(kill *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-sensitive-files.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-python.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}

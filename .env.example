DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/oopsie
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5434/oopsie_test
ENCRYPTION_KEY= # Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
ANTHROPIC_API_KEY=
REDIS_URL=redis://localhost:6379
LOG_LEVEL=INFO
LOG_FORMAT=console  # "json" for production, "console" for dev
GOOGLE_CLIENT_ID= # Google OAuth client ID (from console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_SECRET= # Google OAuth client secret
JWT_SECRET_KEY= # Generate with: python -c 'import secrets; print(secrets.token_urlsafe(64))'
ADMIN_EMAIL=jacobespersen@gmail.com
ORG_NAME=Tonsser
# ── GitHub App ────────────────────────────────────────────────────────────────
# Required for GitHub App integration (cloning repos and creating fix PRs).
# Create a GitHub App at https://github.com/settings/apps/new

# The numeric App ID shown on the app's settings page (e.g. 12345678).
GITHUB_APP_ID=

# RSA private key, base64-encoded. Generate in the app settings under
# "Private keys", then encode: base64 -i path/to/key.pem | tr -d '\n'
GITHUB_APP_PRIVATE_KEY_PEM=

# Webhook secret — set this in the app's webhook settings and copy it here.
# Generate a random secret: python -c 'import secrets; print(secrets.token_hex(32))'
GITHUB_WEBHOOK_SECRET=

# The app slug — the URL-friendly name shown in https://github.com/apps/{slug}
GITHUB_APP_SLUG=
